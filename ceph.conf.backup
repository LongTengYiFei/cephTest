#cyf正在用，请勿修改；
[global]
fsid = 886cee71-e800-4d78-95f4-43b791bfeb50
mon initial members = node1
mon host = 10.26.57.54
public network = 10.26.57.0/24
auth cluster required = cephx
auth service required = cephx
auth client required = cephx
osd journal size = 1024
osd pool default size = 3
osd crush chooseleaf type = 0
setuser match path = /var/lib/ceph
setgroup match path = /var/lib/ceph
ms_type = async+rdma
ms_cluster_type = async+rdma
ms_async_rdma_device_name = mlx5_1
ms_async_rdma_polling_us = 0
ms_async_rdma_local_gid=fe80:0000:0000:0000:a088:c203:0031:ed09
[mon]
mon_allow_pool_delete = true
[client.bootstrap-osd]
keyring = /var/lib/ceph/bootstrap-osd/ceph.keyring